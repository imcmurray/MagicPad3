{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MagicPad Companion",
  "version": "0.3.0",
  "identifier": "app.magicpad.companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MagicPad Companion",
        "width": 980,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Apple Magic Trackpad companion for Windows and Linux",
    "longDescription": "MagicPad Companion detects Apple Magic Trackpad 3 (USB-C) and earlier models, shows battery and connection status, configures gestures and pointer settings, and installs platform drivers/helpers on Windows 11 and EndeavourOS/Arch Linux.",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": []
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "resources": ["../packaging/linux/**/*"]
  },
  "plugins": {}
}
